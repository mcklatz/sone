# Maintainer: lullabyX
pkgname=sone
pkgver=0.8.0
pkgrel=1
pkgdesc="Unofficial Tidal music streaming desktop app"
arch=('x86_64')
url="https://github.com/lullabyX/sone"
license=('GPL-3.0-only')
depends=(
    'webkit2gtk-4.1'
    'gtk3'
    'gstreamer'
    'gst-plugins-base'
    'gst-plugins-good'
    'gst-plugins-bad'
    'gst-libav'
    'libsecret'
    'alsa-lib'
    'librsvg'
    'libayatana-appindicator'
)

# The .deb is built by Tauri and copied alongside this PKGBUILD before makepkg runs.
source=("sone.deb")
sha256sums=('SKIP')
noextract=("sone.deb")

package() {
    cd "$srcdir"
    # Extract the deb: ar extracts control.tar.* and data.tar.*
    ar x sone.deb
    # Extract data.tar.* (contains /usr/bin, /usr/share, etc.) into pkgdir
    tar xf data.tar.* -C "$pkgdir"
}
