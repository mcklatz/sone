{
  "name": "sone",
  "private": true,
  "version": "0.8.0",
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "version": "node sync-version.mjs && cargo update --manifest-path src-tauri/Cargo.toml --workspace && git add src-tauri/tauri.conf.json src-tauri/Cargo.toml src-tauri/Cargo.lock build-scripts/build/PKGBUILD data/io.github.lullabyX.sone.metainfo.xml",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "lint:rust": "cd src-tauri && cargo clippy -- -D warnings",
    "fmt:rust": "cd src-tauri && cargo fmt",
    "fmt:rust:check": "cd src-tauri && cargo fmt --check",
    "knip": "knip",
    "check": "eslint src/ && prettier --check \"src/**/*.{ts,tsx,css}\" && cd src-tauri && cargo clippy -- -D warnings && cargo fmt --check && cd .. && knip"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.18",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "jotai": "^2.17.1",
    "lucide-react": "^0.563.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "knip": "^5.85.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.0.4"
  }
}
